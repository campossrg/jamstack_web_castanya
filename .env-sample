# Copy to .env for local development (do not commit .env)

# --- Site base URL (used in email links, payment redirects) ---
# Local examples: http://localhost:8080 (Eleventy) or http://localhost:8888 (netlify dev)
URL=http://localhost:8080

# --- Supabase (server-side only; used by Netlify Functions via PostgREST) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- RedSys payment provider (server-side only) ---
REDSYS_MERCHANT_CODE=YOUR_REDSYS_MERCHANT_CODE
REDSYS_SECRET_KEY=YOUR_REDSYS_SECRET_KEY_BASE64
# Optional: defaults to RedSys test endpoint when omitted
REDSYS_URL=https://sis-t.redsys.es:25443/sis/realizarPago

# --- SendGrid (server-side only; used by Netlify Functions) ---
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
FROM_EMAIL=no-reply@example.com
CONTACT_EMAIL=contact@example.com

# --- TinaCMS (used for Tina local/dev and builds) ---
TINA_CLIENT_ID=YOUR_TINA_CLIENT_ID
TINA_TOKEN=YOUR_TINA_TOKEN
# Optional: only needed if Tina search indexing is enabled
TINA_SEARCH_TOKEN=YOUR_TINA_SEARCH_TOKEN
