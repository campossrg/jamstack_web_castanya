{% macro recipeFiltersBar(actionUrl, difficultyOptions, dishTypeOptions, searchLabel, showReset, recipes) %}
<form
  class="shop-page-filters__inner"
  action="{{ actionUrl }}"
  method="get"
  data-recipe-filter-form
>
  <details class="shop-page-filter-menu" data-recipe-filter-menu="difficulty" name="recipe-filter-group">
    <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Nivell de dificultat">
      <span data-recipe-filter-summary-label>Nivell de dificultat</span>
      <img class="shop-page-filter__arrow" src="/assets/images/recipe-filter-arrow.svg" alt="" aria-hidden="true" />
    </summary>
    <div class="shop-page-filter-menu__list">
      {% for value in difficultyOptions %}
      <button
        type="button"
        class="shop-page-filter-menu__item recipe-filter-menu__item"
        data-recipe-filter-option
        data-recipe-filter-value="{{ value }}"
        data-recipe-filter-label="{{ value | difficultyLabel }}"
      >{{ value | difficultyLabel }}</button>
      {% endfor %}
    </div>
    <input type="hidden" name="difficulty" data-recipe-filter-input value="" />
  </details>

  <details class="shop-page-filter-menu" data-recipe-filter-menu="time" name="recipe-filter-group">
    <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Temps de preparacio">
      <span data-recipe-filter-summary-label>Temps de preparacio</span>
      <img class="shop-page-filter__arrow" src="/assets/images/recipe-filter-arrow.svg" alt="" aria-hidden="true" />
    </summary>
    <div class="shop-page-filter-menu__list">
      <button type="button" class="shop-page-filter-menu__item recipe-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="short" data-recipe-filter-label="Menys de 20 minuts">Menys de 20 minuts</button>
      <button type="button" class="shop-page-filter-menu__item recipe-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="medium" data-recipe-filter-label="Entre 20 i 30 minuts">Entre 20 i 30 minuts</button>
      <button type="button" class="shop-page-filter-menu__item recipe-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="long" data-recipe-filter-label="Mes de 30 minuts">Mes de 30 minuts</button>
    </div>
    <input type="hidden" name="time" data-recipe-filter-input value="" />
  </details>

  <details class="shop-page-filter-menu" data-recipe-filter-menu="dishType" name="recipe-filter-group">
    <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Tipus de plat">
      <span data-recipe-filter-summary-label>Tipus de plat</span>
      <img class="shop-page-filter__arrow" src="/assets/images/recipe-filter-arrow.svg" alt="" aria-hidden="true" />
    </summary>
    <div class="shop-page-filter-menu__list">
      {% for value in dishTypeOptions %}
      <button
        type="button"
        class="shop-page-filter-menu__item recipe-filter-menu__item"
        data-recipe-filter-option
        data-recipe-filter-value="{{ value }}"
        data-recipe-filter-label="{{ value | dishTypeLabel }}"
      >{{ value | dishTypeLabel }}</button>
      {% endfor %}
    </div>
    <input type="hidden" name="dishType" data-recipe-filter-input value="" />
  </details>

  {% if showReset %}
  <button type="button" class="shop-page-filter" data-recipe-results-reset hidden>
    Esborra filtres
  </button>
  {% endif %}

  <div class="shop-page-search-wrap" data-recipe-search>
    <button type="submit" class="shop-page-search" data-recipe-search-toggle>
      {{ searchLabel }}
      <span aria-hidden="true">&rsaquo;</span>
    </button>
    <input
      type="search"
      class="shop-page-search-input"
      name="q"
      placeholder="Cerca una recepta..."
      autocomplete="off"
      data-recipe-search-input
      hidden
    />
    <div class="shop-page-search-results" data-recipe-search-results hidden></div>
  </div>
</form>
{% if recipes %}
<script type="application/json" data-recipe-search-data>[
  {% for recipe in recipes %}
  {"title": {{ recipe.data.title | dump | safe }}, "url": {{ recipe.url | dump | safe }}}{% if not loop.last %},{% endif %}
  {% endfor %}
]</script>
{% endif %}
{% endmacro %}
