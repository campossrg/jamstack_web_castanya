---
layout: base
---

<div class="post-container">
  
  {# --- SECTION 1: HEADER & META (Matched to Screenshot) --- #}
  <header class="post-header-visual row">
    <div class="header-meta-group">
      {# Date #}
      <time class="post-meta__date" datetime="{{ page.date | htmlDateString }}">
        {{ page.date | readableDate }}
      </time>
      
      {# Title #}
      <h1 class="post-title">{{ title }}</h1>
      
      {# Subtitle (if available, added based on design) #}
      {% if description %}
      <p class="post-subtitle">{{ description }}</p>
      {% endif %}
    </div>

    {# --- The Two-Column Meta Row (Time to Read / Tags) --- #}
    <div class="header-details-grid row">
      <div class="meta-item reading-time col--6">
        <span class="meta-label">Temps de lectura</span>
        {# Example: Add 'readingTime' plugin to 11ty for this #}
        <span class="meta-value">{{ content | readingTime }} minuts</span>
      </div>
      
      <div class="meta-item post-tags col--6">
        <span class="meta-label">Etiquetes</span>
        <span class="meta-value">
          {% for tag in tags %}
            {% if tag != 'update' and tag != 'story' %} {# Skip generic tags #}
            {{ tag }}{% if not loop.last %}, {% endif %}
            {% endif %}
          {% endfor %}
        </span>
      </div>
    </div>
  </header>

  {# --- SECTION 2: HERO IMAGE AREA (Grey box in screenshot) --- #}
  <div class="post-hero-visual row">
    {# Display the 'image' field from Markdown, or default if missing #}
    {% if image %}
    <img src="{{ image }}" alt="Hero image for {{ title }}" class="hero-image">
    {% else %}
    {# Placeholder match for the screenshot #}
    <div class="hero-placeholder"></div>
    {% endif %}
  </div>

  {# --- SECTION 3: MAIN ARTICLE CONTENT (Two-Column Flow) --- #}
  <div class="post-article-flow row">
    <article class="post-content col--8">
      {# The 'safe' filter ensures the Markdown's HTML is rendered #}
      {{ content | safe }}
    </article>
  </div>

</div>