---
layout: base
---

<div class="post">
  {% set product = products[product_key] %}

  <div style="text-align:center; margin:1rem 0;">
    <a href="/shop/products">Products</a> / {{ product.label }}
  </div>

  <div class="product-header">
    <div>
      <img class="product-image" src="{{ product.image }}" />
    </div>

    <div class="product-summary stack">
      <h1 class="product-title">{{ product.label }}</h1>
      <p class="product-price">{{ product.price }}</p>
      <div>
        Vols mes informacio sobre aquest producte?
        <a class="btn btn--buy-now" href="/contact/">
          Contacta amb en Joaquim</a
        >
      </div>
    </div>
  </div>

  <div class="product-desc">
    {{ content | safe }}
  </div>

  <div style="text-align:center; margin:1rem 0;">
    <a href="/shop/products">See more products</a>
  </div>

</div>
